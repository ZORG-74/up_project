flowchart TB
    subgraph "Менеджер заметок"
        
        %% Актеры (пользователи системы)
        Пользователь(["Пользователь"])
        Гость(["Гость (неавторизованный)"])
        
        %% Основные варианты использования (Use Cases)
        usecase1("Зарегистрироваться")
        usecase2("Войти в систему")
        usecase3("Создать заметку")
        usecase4("Просмотреть список заметок")
        usecase5("Просмотреть заметку полностью")
        usecase6("Редактировать заметку")
        usecase7("Удалить заметку")
        usecase8("Искать заметки по ключевым словам")
        usecase9("Сортировать заметки по дате")
        usecase10("Выйти из системы")
        
        %% Связи актеров с use cases
        Гость --> usecase1
        Гость --> usecase2
        
        Пользователь --> usecase3
        Пользователь --> usecase4
        Пользователь --> usecase5
        Пользователь --> usecase6
        Пользователь --> usecase7
        Пользователь --> usecase8
        Пользователь --> usecase9
        Пользователь --> usecase10
        
        %% Отношения между use cases (extend/includes)
        usecase4 -.-> usecase8
        usecase4 -.-> usecase9
        usecase5 -.-> usecase6
        usecase5 -.-> usecase7
    end